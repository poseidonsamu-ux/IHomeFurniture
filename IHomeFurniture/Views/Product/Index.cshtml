@model IEnumerable<IHomeFurniture.Models.SANPHAM>
@{
    ViewBag.Title = "Cửa hàng Nội thất | iHOME";
    Layout = "~/Views/Shared/_Layout.cshtml";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPage ?? 1;
}

<div class="bg-zinc-50 py-16 md:py-24 border-b border-zinc-100 text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-30 pointer-events-none">
        <div class="absolute top-[-50%] left-[20%] w-[50%] h-[200%] bg-orange-50 blur-[100px] rotate-45"></div>
    </div>
    <div class="relative z-10">
        <h1 class="text-4xl md:text-5xl font-light text-black mb-4">
            @if (!string.IsNullOrEmpty(ViewBag.SearchTerm))
            {
                <text>Bộ sưu tập <span class="font-bold">@ViewBag.SearchTerm</span></text>
            }
            else
            {
                <text>Tất cả <span class="font-bold">Sản phẩm</span></text>
            }
        </h1>
        <p class="text-zinc-400 text-xs tracking-[0.3em] uppercase font-bold">Kiến tạo không gian sống mơ ước</p>
    </div>
</div>

<section class="py-16 max-w-[1440px] mx-auto px-6 lg:px-12 flex flex-col lg:flex-row gap-12">

    <aside class="w-full lg:w-64 flex-shrink-0 space-y-10 hidden lg:block">
        <div>
            <h3 class="text-xs font-black uppercase tracking-widest text-black mb-6">Danh mục</h3>
            <ul class="space-y-4 text-sm text-zinc-500 font-medium">
                <li><a href="/Product/Index?priceRange=@ViewBag.PriceRange&searchTerm=@ViewBag.SearchTerm" class="hover:text-orange-500 transition-colors flex justify-between @(ViewBag.CategoryId == null ? "text-orange-500 font-bold" : "")"><span>Tất cả</span></a></li>
                <li><a href="/Product/Index?categoryId=1&priceRange=@ViewBag.PriceRange&searchTerm=@ViewBag.SearchTerm" class="hover:text-orange-500 transition-colors flex justify-between @(ViewBag.CategoryId == 1 ? "text-orange-500 font-bold" : "")"><span>Phòng khách</span></a></li>
                <li><a href="/Product/Index?categoryId=2&priceRange=@ViewBag.PriceRange&searchTerm=@ViewBag.SearchTerm" class="hover:text-orange-500 transition-colors flex justify-between @(ViewBag.CategoryId == 2 ? "text-orange-500 font-bold" : "")"><span>Phòng ngủ</span></a></li>
                <li><a href="/Product/Index?categoryId=3&priceRange=@ViewBag.PriceRange&searchTerm=@ViewBag.SearchTerm" class="hover:text-orange-500 transition-colors flex justify-between @(ViewBag.CategoryId == 3 ? "text-orange-500 font-bold" : "")"><span>Phòng ăn</span></a></li>
            </ul>
        </div>

        <div>
            <h3 class="text-xs font-black uppercase tracking-widest text-black mb-6">Mức giá</h3>
            <ul class="space-y-4 text-sm text-zinc-500 font-medium">
                <li>
                    <a href="/Product/Index?categoryId=@ViewBag.CategoryId&searchTerm=@ViewBag.SearchTerm" class="flex items-center gap-3 cursor-pointer hover:text-black @(string.IsNullOrEmpty(ViewBag.PriceRange) ? "text-orange-500 font-bold" : "")">
                        <i class="fa-solid fa-rotate-left text-xs"></i> Tất cả mức giá
                    </a>
                </li>
                <li>
                    <a href="/Product/Index?categoryId=@ViewBag.CategoryId&priceRange=under2&searchTerm=@ViewBag.SearchTerm" class="flex items-center gap-3 cursor-pointer hover:text-black">
                        <div class="w-4 h-4 border rounded-sm flex items-center justify-center transition-colors @(ViewBag.PriceRange == "under2" ? "bg-orange-500 border-orange-500 text-white" : "border-zinc-300 text-transparent")"><i class="fa-solid fa-check text-[10px]"></i></div>
                        Dưới 2 triệu
                    </a>
                </li>
                <li>
                    <a href="/Product/Index?categoryId=@ViewBag.CategoryId&priceRange=2to5&searchTerm=@ViewBag.SearchTerm" class="flex items-center gap-3 cursor-pointer hover:text-black">
                        <div class="w-4 h-4 border rounded-sm flex items-center justify-center transition-colors @(ViewBag.PriceRange == "2to5" ? "bg-orange-500 border-orange-500 text-white" : "border-zinc-300 text-transparent")"><i class="fa-solid fa-check text-[10px]"></i></div>
                        2 - 5 triệu
                    </a>
                </li>
                <li>
                    <a href="/Product/Index?categoryId=@ViewBag.CategoryId&priceRange=5to10&searchTerm=@ViewBag.SearchTerm" class="flex items-center gap-3 cursor-pointer hover:text-black">
                        <div class="w-4 h-4 border rounded-sm flex items-center justify-center transition-colors @(ViewBag.PriceRange == "5to10" ? "bg-orange-500 border-orange-500 text-white" : "border-zinc-300 text-transparent")"><i class="fa-solid fa-check text-[10px]"></i></div>
                        5 - 10 triệu
                    </a>
                </li>
                <li>
                    <a href="/Product/Index?categoryId=@ViewBag.CategoryId&priceRange=over10&searchTerm=@ViewBag.SearchTerm" class="flex items-center gap-3 cursor-pointer hover:text-black">
                        <div class="w-4 h-4 border rounded-sm flex items-center justify-center transition-colors @(ViewBag.PriceRange == "over10" ? "bg-orange-500 border-orange-500 text-white" : "border-zinc-300 text-transparent")"><i class="fa-solid fa-check text-[10px]"></i></div>
                        Trên 10 triệu
                    </a>
                </li>
            </ul>
        </div>
    </aside>

    <div class="flex-1">

        <div class="flex flex-col sm:flex-row justify-between items-center mb-8 gap-4 pb-4 border-b border-zinc-100">
            <span class="text-[11px] font-bold text-zinc-400 uppercase tracking-widest">
                Hiển thị <span class="text-black">@ViewBag.TotalItem</span> sản phẩm (Trang @ViewBag.CurrentPage)
            </span>
            <div class="flex items-center gap-3 text-sm">
                <span class="text-zinc-400 text-[11px] uppercase tracking-widest font-bold">Sắp xếp:</span>
                <select class="bg-transparent text-black font-medium outline-none cursor-pointer hover:text-orange-500 transition-colors">
                    <option>Mới nhất</option>
                    <option>Giá tăng dần</option>
                    <option>Giá giảm dần</option>
                    <option>Bán chạy</option>
                </select>
            </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-12">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="group">
                        <div class="relative overflow-hidden aspect-[4/5] bg-zinc-50 rounded-sm mb-4 cursor-pointer" onclick="window.location.href='/Product/Detail/@item.MaSP'">
                            <img src="~/Images/@item.AnhBia" alt="@item.TenSP" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">

                            @if (item.GiaKhuyenMai > 0 && item.GiaKhuyenMai < item.GiaBan)
                            {
                                <div class="absolute top-4 left-4 bg-orange-500 text-white text-[10px] px-2 py-1 uppercase tracking-widest font-bold">Sale</div>
                            }
                            else
                            {
                                <div class="absolute top-4 left-4 bg-black text-white text-[10px] px-2 py-1 uppercase tracking-widest">New</div>
                            }

                            <div class="absolute inset-x-0 bottom-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300 bg-gradient-to-t from-black/60 to-transparent">
                                <button type="button" onclick="openQuantityModal(event, @item.MaSP)" class="w-full bg-white text-black h-12 rounded-full text-[10px] font-black uppercase tracking-[0.1em] hover:bg-orange-500 hover:text-white transition-all shadow-lg active:scale-95 flex items-center justify-center gap-2">
                                    <i class="fa-solid fa-cart-plus"></i> Thêm vào giỏ
                                </button>
                            </div>
                        </div>

                        <div>
                            <a href="/Product/Detail/@item.MaSP" class="text-sm font-medium text-zinc-800 hover:text-orange-500 transition-colors line-clamp-1">@item.TenSP</a>
                            <div class="flex items-center gap-3 mt-1.5">
                                @if (item.GiaKhuyenMai > 0 && item.GiaKhuyenMai < item.GiaBan)
                                {
                                    <span class="text-sm font-bold text-orange-500">@String.Format("{0:N0}", item.GiaKhuyenMai)đ</span>
                                    <span class="text-[11px] text-zinc-400 line-through">@String.Format("{0:N0}", item.GiaBan)đ</span>
                                }
                                else
                                {
                                    <span class="text-sm font-bold text-black">@String.Format("{0:N0}", item.GiaBan)đ</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-span-full py-20 text-center">
                    <i class="fa-solid fa-box-open text-4xl text-zinc-300 mb-4 block"></i>
                    <p class="text-zinc-500 font-medium">Hiện tại chưa có sản phẩm nào phù hợp với bộ lọc.</p>
                </div>
            }
        </div>

        <div class="mt-16 flex justify-center gap-2">
            @if (ViewBag.TotalPage != null && ViewBag.TotalPage > 1)
            {
                if (ViewBag.CurrentPage > 1)
                {
                    <a href="/Product/Index?page=@(ViewBag.CurrentPage - 1)&categoryId=@ViewBag.CategoryId&priceRange=@ViewBag.PriceRange&searchTerm=@ViewBag.SearchTerm" class="w-10 h-10 flex items-center justify-center bg-white border border-zinc-200 text-zinc-500 hover:border-black hover:text-black rounded-full text-sm font-medium transition-colors">
                        <i class="fa-solid fa-chevron-left text-[10px]"></i>
                    </a>
                }

                for (int i = 1; i <= ViewBag.TotalPage; i++)
                {
                    if (i == ViewBag.CurrentPage)
                    {
                        <span class="w-10 h-10 flex items-center justify-center bg-black text-white rounded-full text-sm font-bold shadow-md pointer-events-none">@i</span>
                    }
                    else
                    {
                        <a href="/Product/Index?page=@i&categoryId=@ViewBag.CategoryId&priceRange=@ViewBag.PriceRange&searchTerm=@ViewBag.SearchTerm" class="w-10 h-10 flex items-center justify-center bg-white border border-zinc-200 text-zinc-500 hover:border-black hover:text-black rounded-full text-sm font-medium transition-colors">@i</a>
                    }
                }

                if (ViewBag.CurrentPage < ViewBag.TotalPage)
                {
                    <a href="/Product/Index?page=@(ViewBag.CurrentPage + 1)&categoryId=@ViewBag.CategoryId&priceRange=@ViewBag.PriceRange&searchTerm=@ViewBag.SearchTerm" class="w-10 h-10 flex items-center justify-center bg-white border border-zinc-200 text-zinc-500 hover:border-black hover:text-black rounded-full text-sm font-medium transition-colors">
                        <i class="fa-solid fa-chevron-right text-[10px]"></i>
                    </a>
                }
            }
        </div>

    </div>
</section>