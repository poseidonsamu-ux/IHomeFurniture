@model IHomeFurniture.Models.SANPHAM
@{
    ViewBag.Title = "Thêm sản phẩm mới";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="min-h-screen bg-gray-50 py-8 px-8">

    <div class="mb-6 flex items-center text-sm text-gray-500">
        <a href="/Admin/QuanLySanPham" class="hover:text-blue-600 transition"><i class="fa-solid fa-arrow-left mr-2"></i> Quay lại kho sản phẩm</a>
    </div>

    <div class="bg-white p-8 sm:p-10 rounded-2xl shadow-[0_2px_20px_rgba(0,0,0,0.04)] border border-gray-100">
        <h2 class="text-2xl font-bold text-gray-900 mb-8 pb-4 border-b border-gray-100">
            <i class="fa-solid fa-couch text-blue-500 mr-2"></i> Đăng Sản Phẩm Nội Thất Mới
        </h2>

        @if (ViewBag.Error != null)
        {
            <div class="bg-red-50 text-red-600 p-4 rounded-xl mb-6 border border-red-100 font-medium flex items-center">
                <i class="fa-solid fa-circle-exclamation mr-2"></i> @ViewBag.Error
            </div>
        }

        @using (Html.BeginForm("ThemSanPham", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
                <div class="lg:col-span-2 space-y-6">
                    <div>
                        <label class="block text-sm font-semibold mb-2 text-gray-700">Tên sản phẩm <span class="text-red-500">*</span></label>
                        <input type="text" name="TenSP" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 outline-none transition-all" placeholder="VD: Sofa Băng Góc L Da Ý..." />
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <label class="block text-sm font-semibold mb-2 text-gray-700">Giá bán (VNĐ) <span class="text-red-500">*</span></label>
                            <input type="number" name="GiaBan" required min="0" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 outline-none transition-all font-bold text-red-500" placeholder="0" />
                        </div>
                        <div>
                            <label class="block text-sm font-semibold mb-2 text-gray-700">Giá KM (Tùy chọn)</label>
                            <input type="number" name="GiaKhuyenMai" value="0" min="0" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 outline-none transition-all text-orange-500 font-bold" />
                        </div>
                        <div>
                            <label class="block text-sm font-semibold mb-2 text-gray-700">Số lượng kho</label>
                            <input type="number" name="SoLuongTon" value="0" min="0" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 outline-none transition-all" />
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <label class="block text-sm font-semibold mb-2 text-gray-700">Chất liệu</label>
                            <input type="text" name="ChatLieu" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 outline-none transition-all" placeholder="VD: Da Bò, Gỗ Sồi..." />
                        </div>
                        <div>
                            <label class="block text-sm font-semibold mb-2 text-gray-700">Kích thước</label>
                            <input type="text" name="KichThuoc" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 outline-none transition-all" placeholder="VD: 2.8m x 1.6m" />
                        </div>
                        <div>
                            <label class="block text-sm font-semibold mb-2 text-gray-700">Màu sắc</label>
                            <input type="text" name="MauSac" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 outline-none transition-all" placeholder="VD: Nâu Tây, Be..." />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold mb-2 text-gray-700">Mô tả chi tiết</label>
                        <textarea name="MoTa" rows="5" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 outline-none transition-all resize-none" placeholder="Viết mô tả chi tiết về sản phẩm nội thất này..."></textarea>
                    </div>
                </div>

                <div class="space-y-6 bg-gray-50/50 p-6 rounded-2xl border border-gray-100">
                    <div>
                        <label class="block text-sm font-semibold mb-2 text-gray-700">Ảnh bìa chính</label>
                        <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-xl hover:border-blue-500 transition-colors bg-white">
                            <div class="space-y-1 text-center">
                                <i class="fa-solid fa-cloud-arrow-up text-3xl text-gray-400 mb-2"></i>
                                <div class="flex text-sm text-gray-600 justify-center">
                                    <label class="relative cursor-pointer bg-white rounded-md font-medium text-blue-600 hover:text-blue-500">
                                        <span>Tải ảnh lên</span>
                                        <input id="file-upload" name="HinhAnh" type="file" class="sr-only" required>
                                    </label>
                                </div>
                                <p class="text-xs text-gray-500 mt-1">PNG, JPG, JPEG tối đa 2MB</p>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold mb-2 text-gray-700">Danh mục sản phẩm <span class="text-red-500">*</span></label>
                        @Html.DropDownList("MaDM", null, "-- Chọn danh mục --", new { @class = "w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all", required = "required" })
                    </div>

                    <div>
                        <label class="block text-sm font-semibold mb-2 text-gray-700">Thương hiệu <span class="text-red-500">*</span></label>
                        @Html.DropDownList("MaTH", null, "-- Chọn thương hiệu --", new { @class = "w-full px-4 py-3 bg-white border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none transition-all", required = "required" })
                    </div>

                    <button type="submit" class="w-full bg-blue-600 text-white font-bold py-3.5 rounded-xl shadow-lg shadow-blue-500/30 hover:bg-blue-700 hover:-translate-y-0.5 transition-all mt-4">
                        <i class="fa-solid fa-floppy-disk mr-2"></i> LƯU SẢN PHẨM
                    </button>
                </div>
            </div>
        }
    </div>
</div>