@model IHomeFurniture.Models.DONDATHANG
@{
    ViewBag.Title = "Chi tiết đơn hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    var listSP = ViewBag.ListChiTiet as List<IHomeFurniture.Models.CHITIETDATHANG>;
}

<div class="max-w-5xl mx-auto py-8 px-4">
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-bold text-gray-900 tracking-tight uppercase">Chi Tiết Hóa Đơn</h2>
            <p class="text-gray-500 mt-1 font-bold">Mã: <span class="text-blue-600">#ORD-@Model.MaDonHang</span></p>
        </div>
        <a href="/Admin/QuanLyDonHang" class="flex items-center text-zinc-400 hover:text-black transition-colors font-bold text-sm">
            <i class="fa-solid fa-arrow-left mr-2"></i> QUAY LẠI DANH SÁCH
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
            <p class="text-[10px] font-black text-zinc-400 uppercase tracking-widest mb-4 text-blue-600">Người đặt hàng</p>
            <p class="font-bold text-gray-900 text-lg">@Model.KHACHHANG.HoTen</p>
            <p class="text-sm text-gray-500 mt-1 italic">SĐT: @Model.DienThoaiNhan</p>
        </div>

        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
            <p class="text-[10px] font-black text-zinc-400 uppercase tracking-widest mb-4 text-orange-600">Địa chỉ giao hàng</p>
            <p class="text-sm font-bold text-gray-800 leading-relaxed">
                @(Model.KHACHHANG != null ? Model.KHACHHANG.DiaChi : "Chưa cập nhật")
            </p>
        </div>

        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
            <p class="text-[10px] font-black text-zinc-400 uppercase tracking-widest mb-4 text-green-600">Cập nhật trạng thái</p>

            @using (Html.BeginForm("CapNhatTrangThai", "Admin", FormMethod.Post))
            {
                <input type="hidden" name="MaDonHang" value="@Model.MaDonHang" />

                <div class="flex flex-col gap-3">
                    @Html.DropDownList("MaTT", null, new { @class = "w-full p-2.5 bg-zinc-50 border border-zinc-200 rounded-xl text-xs font-bold focus:ring-2 focus:ring-blue-500 outline-none" })

                    <button type="submit" class="w-full bg-zinc-900 hover:bg-black text-white py-2.5 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all active:scale-95 shadow-md">
                        Xác nhận đổi
                    </button>
                </div>
            }
            <p class="text-[10px] text-gray-400 mt-3 italic">Ngày đặt: @(Model.NgayDat.HasValue ? Model.NgayDat.Value.ToString("dd/MM/yyyy HH:mm") : "N/A")</p>
        </div>
    </div>

    <div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-zinc-50 border-b border-zinc-100 text-zinc-400 text-[10px] font-black uppercase tracking-widest">
                    <th class="p-6">Sản phẩm nội thất</th>
                    <th class="p-6 text-center">SL</th>
                    <th class="p-6 text-right">Đơn giá</th>
                    <th class="p-6 text-right">Thành tiền</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-zinc-50 text-sm">
                @if (listSP != null)
                { 
                    foreach (var item in listSP)
                    {
                        <tr class="hover:bg-zinc-50/50 transition-colors">
                            <td class="p-6">
                                <div class="flex items-center space-x-4">
                                    <img src="~/Images/@item.SANPHAM.AnhBia" class="w-12 h-12 object-cover rounded-xl shadow-sm border" onerror="this.src='https://placehold.co/100x100?text=iHome'">
                                    <div>
                                        <p class="font-bold text-gray-900">@item.SANPHAM.TenSP</p>
                                        <p class="text-[10px] text-zinc-400 uppercase">Mã SP: @item.MaSP</p>
                                    </div>
                                </div>
                            </td>
                            <td class="p-6 text-center font-bold text-gray-600">@item.SoLuong</td>
                            <td class="p-6 text-right text-gray-500">@String.Format("{0:N0}", item.DonGia) đ</td>
                            <td class="p-6 text-right font-black text-gray-900">@String.Format("{0:N0}", (item.SoLuong * item.DonGia)) đ</td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot class="bg-zinc-50 border-t border-zinc-100">
                <tr class="font-black text-gray-900">
                    <td colspan="3" class="p-6 text-right text-zinc-400 uppercase text-[10px] tracking-widest">Tổng cộng thanh toán:</td>
                    <td class="p-6 text-right text-2xl text-red-600">@String.Format("{0:N0}", Model.TongTien) đ</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>