@model IHomeFurniture.Models.TINTUC
@{
    ViewBag.Title = "Chỉnh sửa bài viết";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}
<script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>

<div class="max-w-5xl mx-auto">
    <div class="mb-8 flex items-center justify-between">
        <h2 class="text-3xl font-bold text-gray-800">SỬA BÀI VIẾT</h2>
        <a href="/Admin/QuanLyTinTuc" class="text-sm text-zinc-400 hover:text-black transition-colors">
            <i class="fa-solid fa-arrow-left mr-1"></i> Quay lại danh sách
        </a>
    </div>

    @* ĐÃ FIX: Thêm new { id = Model.MaTin } và AntiForgeryToken bên dưới *@
    @using (Html.BeginForm("SuaTinTuc", "Admin", new { id = Model.MaTin }, FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.MaTin)

        <div class="bg-white p-10 rounded-3xl border border-zinc-100 shadow-sm space-y-6">

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="md:col-span-2">
                    <label class="block text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">Tiêu đề bài viết</label>
                    <input type="text" name="TieuDe" value="@Model.TieuDe" required class="w-full p-4 bg-zinc-50 border-none rounded-2xl focus:ring-2 focus:ring-black outline-none font-bold" />
                </div>
                <div>
                    <label class="block text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">Ngày đăng</label>
                    <input type="datetime-local" name="NgayDang"
                           value="@(Model.NgayDang.HasValue ? Model.NgayDang.Value.ToString("yyyy-MM-ddTHH:mm") : "")"
                           required class="w-full p-4 bg-zinc-50 border-none rounded-2xl focus:ring-2 focus:ring-black outline-none font-bold text-zinc-700" />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
                <div>
                    <label class="block text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">Thay ảnh bìa mới (nếu có)</label>
                    <input type="file" name="fAnhTin" class="w-full p-4 bg-zinc-50 rounded-2xl border-2 border-dashed border-zinc-200" />
                </div>
                <div class="text-center">
                    <p class="text-[10px] text-zinc-400 uppercase mb-2">Ảnh hiện tại</p>
                    <img src="@Url.Content("~/Images/News/" + Model.AnhTin)" onerror="this.src='https://placehold.co/100x80?text=No+Img'" class="h-24 mx-auto rounded-lg shadow-md object-cover" />
                </div>
            </div>

            <div>
                <label class="block text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">Nội dung chi tiết</label>
                <textarea name="NoiDung" id="NoiDung">@Model.NoiDung</textarea>
                <script>CKEDITOR.replace('NoiDung');</script>
            </div>

            <button type="submit" class="w-full bg-black text-white py-4 rounded-2xl font-bold shadow-xl hover:bg-zinc-800 transition-all uppercase tracking-widest active:scale-95">
                Lưu thay đổi bài viết
            </button>
        </div>
    }
</div>