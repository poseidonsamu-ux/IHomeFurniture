@model IHomeFurniture.Models.TINTUC
@{
    ViewBag.Title = "Viết bài mới";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

@* Nhúng bộ soạn thảo Word (CKEditor) *@
<script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>

<div class="max-w-5xl mx-auto p-8">
    <div class="mb-8">
        <h2 class="text-3xl font-bold text-gray-800">SOẠN THẢO BÀI VIẾT</h2>
        <p class="text-gray-500">Nội dung bài viết sẽ hiển thị ở mục "Góc Cảm Hứng" trang chủ.</p>
    </div>

    @using (Html.BeginForm("ThemTinTuc", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        <div class="space-y-6 bg-white p-10 rounded-3xl border border-zinc-100 shadow-sm">
            <div>
                <label class="block text-sm font-bold text-zinc-700 mb-2 uppercase tracking-widest">Tiêu đề bài viết</label>
                <input type="text" name="TieuDe" required class="w-full p-4 bg-zinc-50 border-none rounded-2xl focus:ring-2 focus:ring-black outline-none font-bold text-lg" placeholder="Nhập tiêu đề hấp dẫn..." />
            </div>

            <div>
                <label class="block text-sm font-bold text-zinc-700 mb-2 uppercase tracking-widest">Ảnh bìa tin tức</label>
                <input type="file" name="fAnhTin" accept="image/*" required class="w-full p-4 bg-zinc-50 rounded-2xl border-2 border-dashed border-zinc-200" />
            </div>

            <div>
                <label class="block text-sm font-bold text-zinc-700 mb-2 uppercase tracking-widest">Nội dung chi tiết</label>
                <textarea name="NoiDung" id="NoiDung"></textarea>
                <script>CKEDITOR.replace('NoiDung');</script>
            </div>

            <div class="flex justify-end gap-4 pt-6">
                <a href="/Admin/QuanLyTinTuc" class="px-8 py-4 text-zinc-400 font-bold hover:text-zinc-800 transition-colors">Hủy bỏ</a>
                <button type="submit" class="bg-black text-white px-10 py-4 rounded-2xl font-bold shadow-xl hover:bg-zinc-800 transition-all">
                    ĐĂNG BÀI NGAY
                </button>
            </div>
        </div>
    }
</div>