@model IHomeFurniture.Models.KHACHHANG
@{
    ViewBag.Title = "Cập nhật Khách Hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="p-10">
    <div class="max-w-2xl mx-auto bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
        <h2 class="text-2xl font-bold mb-6">Cập nhật thông tin: <span class="text-blue-600">@Model.TaiKhoan</span></h2>

        @using (Html.BeginForm("SuaKhachHang", "Admin", FormMethod.Post))
        {
            @Html.HiddenFor(m => m.MaKH)

            if (ViewBag.Error != null)
            {
                <div class="bg-red-50 text-red-500 p-3 rounded mb-4">@ViewBag.Error</div>
            }

            <div class="grid grid-cols-2 gap-6 mb-6">
                <div>
                    <label class="block text-sm font-semibold mb-2">Họ Tên</label>
                    @Html.TextBoxFor(m => m.HoTen, new { @class = "w-full p-3 border rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" })
                </div>
                <div>
                    <label class="block text-sm font-semibold mb-2">Số Điện Thoại</label>
                    @Html.TextBoxFor(m => m.DienThoai, new { @class = "w-full p-3 border rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" })
                </div>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-semibold mb-2">Email</label>
                @Html.TextBoxFor(m => m.Email, new { @class = "w-full p-3 border rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" })
            </div>

            <div class="mb-6">
                <label class="block text-sm font-semibold mb-2">Địa Chỉ</label>
                @Html.TextAreaFor(m => m.DiaChi, new { @class = "w-full p-3 border rounded-xl focus:ring-2 focus:ring-blue-500 outline-none", rows = "3" })
            </div>

            <div class="mb-8">
                <label class="block text-sm font-semibold mb-2">Trạng Thái Tài Khoản</label>
                @Html.DropDownListFor(m => m.TrangThai, new SelectList(new[] {
                    new { Value = true, Text = "Bình thường (Mở khóa)" },
                    new { Value = false, Text = "Khóa tài khoản" }
                }, "Value", "Text", Model.TrangThai), new { @class = "w-full p-3 border rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" })
            </div>

            <div class="flex space-x-4">
                <button type="submit" class="bg-blue-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-blue-700 transition">CẬP NHẬT LƯU</button>
                <a href="/Admin/QuanLyKhachHang" class="bg-gray-100 text-gray-700 px-8 py-3 rounded-xl font-bold hover:bg-gray-200 transition">Hủy bỏ</a>
            </div>
        }
    </div>
</div>