@{
    Layout = null; // Không dùng Layout
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>iHOME - Đăng nhập Quản trị</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>
<body class="bg-white antialiased">

    <div class="min-h-screen flex items-center justify-center bg-white px-4 py-20 relative overflow-hidden">

        <div class="absolute top-0 left-0 w-full h-full opacity-40 pointer-events-none">
            <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-orange-50 rounded-full blur-[120px]"></div>
            <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-zinc-100 rounded-full blur-[120px]"></div>
        </div>

        <div class="max-w-[480px] w-full relative z-10">

            <div class="mb-12">
                <h1 class="text-7xl font-black text-black tracking-tighter leading-none mb-4">
                    ĐĂNG <br /> <span class="text-orange-500">NHẬP.</span>
                </h1>
                <p class="text-zinc-400 text-xs tracking-[0.4em] uppercase font-bold ml-1">Hệ thống Quản trị viên</p>
            </div>

            <div class="bg-white p-10 rounded-2xl border border-zinc-100 shadow-[0_20px_50px_rgba(0,0,0,0.04)]">

                @using (Html.BeginForm())
                {
                    if (ViewBag.Error != null)
                    {
                        <div class="bg-red-50 border border-red-100 text-red-500 p-4 rounded-xl text-xs font-bold mb-8 flex items-center gap-3">
                            <i class="fa-solid fa-triangle-exclamation"></i>
                            <span>@ViewBag.Error</span>
                        </div>
                    }

                    <div class="space-y-8">
                        <div class="space-y-2">
                            <label class="text-[11px] uppercase tracking-widest font-black text-zinc-400 ml-1">Tên đăng nhập</label>
                            <div class="relative group">
                                <i class="fa-regular fa-user absolute left-4 top-1/2 -translate-y-1/2 text-zinc-300 group-focus-within:text-orange-500 transition-colors"></i>
                                <input type="text" name="TenDN" required autofocus
                                       placeholder="Nhập tài khoản quản trị..."
                                       class="w-full bg-zinc-50 border border-zinc-100 rounded-xl py-4 pl-12 pr-4 text-black outline-none focus:bg-white focus:border-orange-500/50 focus:ring-4 focus:ring-orange-500/5 transition-all placeholder:text-zinc-300 text-sm font-medium" />
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="text-[11px] uppercase tracking-widest font-black text-zinc-400 ml-1">Mật khẩu</label>
                            <div class="relative group">
                                <i class="fa-solid fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-zinc-300 group-focus-within:text-orange-500 transition-colors"></i>
                                <input type="password" name="MatKhau" required
                                       placeholder="••••••••"
                                       class="w-full bg-zinc-50 border border-zinc-100 rounded-xl py-4 pl-12 pr-4 text-black outline-none focus:bg-white focus:border-orange-500/50 focus:ring-4 focus:ring-orange-500/5 transition-all placeholder:text-zinc-300 text-sm font-medium" />
                            </div>
                        </div>

                        <button type="submit"
                                class="w-full bg-zinc-900 hover:bg-orange-600 text-white py-4 rounded-full font-black text-xs uppercase tracking-[0.2em] transition-all duration-300 shadow-xl shadow-zinc-200 hover:shadow-orange-200 active:scale-95 flex items-center justify-center gap-3 mt-6">
                            <span>ĐĂNG NHẬP HỆ THỐNG</span>
                            <i class="fa-solid fa-arrow-right-long text-xs transition-transform group-hover:translate-x-1"></i>
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</body>
</html>