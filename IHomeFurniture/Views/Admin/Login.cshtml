@{
    Layout = null; // Không dùng Layout
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>iHOME - Đăng nhập Quản trị</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-gradient-to-br from-indigo-50 via-white to-blue-50 h-screen flex items-center justify-center font-['Inter'] antialiased">

    <div class="bg-white p-10 sm:p-12 rounded-3xl shadow-[0_20px_50px_rgba(8,_112,_184,_0.07)] w-full max-w-md border border-gray-100">

        <div class="text-center mb-10">
            <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight mb-1">
                iHOME<span class="text-blue-600">.</span>
            </h1>
            <p class="text-gray-500 text-sm font-medium">Hệ thống Quản trị viên</p>
        </div>

        @using (Html.BeginForm())
        {
            if (ViewBag.Error != null)
            {
                <div class="bg-red-50 text-red-600 text-sm p-4 rounded-xl text-center mb-6 border border-red-100 font-medium">
                    @ViewBag.Error
                </div>
            }

            <div class="space-y-5">
                <div>
                    <label class="block text-sm font-semibold mb-2 text-gray-700">Tên đăng nhập</label>
                    <input type="text" name="TenDN" required autofocus
                           class="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all duration-200 text-gray-800"
                           placeholder="Nhập tài khoản quản trị..." />
                </div>

                <div>
                    <label class="block text-sm font-semibold mb-2 text-gray-700">Mật khẩu</label>
                    <input type="password" name="MatKhau" required
                           class="w-full px-5 py-3.5 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all duration-200 text-gray-800"
                           placeholder="••••••••" />
                </div>

                <button type="submit"
                        class="w-full bg-blue-600 hover:bg-blue-700 active:transform active:scale-[0.98] text-white font-bold py-3.5 rounded-xl shadow-lg shadow-blue-600/30 transition-all duration-200 mt-8">
                    ĐĂNG NHẬP HỆ THỐNG
                </button>
            </div>
        }
    </div>
</body>
</html>