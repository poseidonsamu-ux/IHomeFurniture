@{
    Layout = null; // Không dùng Layout
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>iHOME - Đăng nhập Quản trị</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-gray-900 h-screen flex items-center justify-center font-['Inter']">
    <div class="bg-white p-10 rounded-xl shadow-2xl w-full max-w-sm">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-900 tracking-widest">iHOME<span class="text-blue-500">.</span></h1>
            <p class="text-gray-500 text-sm mt-2">Hệ thống quản trị viên</p>
        </div>

        @using (Html.BeginForm())
        {
            if (ViewBag.Error != null)
            {
                <div class="bg-red-50 text-red-600 text-sm p-3 rounded-lg text-center mb-4 border border-red-100">
                    @ViewBag.Error
                </div>
            }

            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-semibold mb-1 text-gray-700">Tên đăng nhập</label>
                    <input type="text" name="TenDN" required autofocus class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-blue-500 outline-none transition" placeholder="admin_tong" />
                </div>
                <div>
                    <label class="block text-sm font-semibold mb-1 text-gray-700">Mật khẩu</label>
                    <input type="password" name="MatKhau" required class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:bg-white focus:ring-2 focus:ring-blue-500 outline-none transition" placeholder="••••••••" />
                </div>
                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-lg transition mt-4">
                    ĐĂNG NHẬP HỆ THỐNG
                </button>
            </div>
        }
    </div>
</body>
</html>