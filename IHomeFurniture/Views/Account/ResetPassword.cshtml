@{
    ViewBag.Title = "Đặt lại mật khẩu | iHOME";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen flex items-center justify-center bg-zinc-50 py-16 px-4">
    <div class="max-w-[450px] w-full bg-white p-10 rounded-2xl border border-zinc-100 shadow-sm text-center">

        <h2 class="text-3xl font-light text-black mb-2">Đặt lại <span class="font-bold">Mật khẩu</span></h2>
        <p class="text-xs text-zinc-400 mb-8 leading-relaxed">Mã OTP đã được gửi tới <br><strong class="text-black">@ViewBag.Email</strong></p>

        @using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="email" value="@ViewBag.Email" />

            if (ViewBag.Error != null)
            {
                <div class="bg-red-50 text-red-500 p-3 rounded-xl text-[11px] font-bold mb-6 border border-red-100">
                    @ViewBag.Error
                </div>
            }

            <div class="space-y-4 text-left">
                <div class="relative group">
                    <i class="fa-solid fa-shield-halved absolute left-4 top-1/2 -translate-y-1/2 text-zinc-300 group-focus-within:text-orange-500"></i>
                    <input type="text" name="otp" required maxlength="6" placeholder="Nhập mã OTP 6 số" class="w-full bg-zinc-50 border border-zinc-100 rounded-xl py-4 pl-12 pr-4 text-black text-sm font-bold tracking-widest focus:bg-white focus:border-orange-500 outline-none transition-all" />
                </div>

                <div class="relative group">
                    <i class="fa-solid fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-zinc-300 group-focus-within:text-orange-500"></i>
                    <input type="password" name="newPassword" required placeholder="Mật khẩu mới (tối thiểu 8 ký tự)" class="w-full bg-zinc-50 border border-zinc-100 rounded-xl py-4 pl-12 pr-4 text-black text-sm font-medium focus:bg-white focus:border-orange-500 outline-none transition-all" />
                </div>

                <div class="relative group">
                    <i class="fa-solid fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-zinc-300 group-focus-within:text-orange-500"></i>
                    <input type="password" name="confirmPassword" required placeholder="Nhập lại mật khẩu mới" class="w-full bg-zinc-50 border border-zinc-100 rounded-xl py-4 pl-12 pr-4 text-black text-sm font-medium focus:bg-white focus:border-orange-500 outline-none transition-all" />
                </div>

                <button type="submit" class="w-full bg-orange-500 hover:bg-black text-white py-4 rounded-full text-xs font-black uppercase tracking-widest transition-all mt-4 shadow-lg shadow-orange-500/30">
                    Cập nhật mật khẩu
                </button>
            </div>
        }
    </div>
</div>