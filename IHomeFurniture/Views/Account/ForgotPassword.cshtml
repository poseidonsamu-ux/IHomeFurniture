@{
    ViewBag.Title = "Quên mật khẩu | iHOME";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen flex items-center justify-center bg-zinc-50 py-16 px-4">
    <div class="max-w-[450px] w-full bg-white p-10 rounded-2xl border border-zinc-100 shadow-sm text-center">

        <div class="w-16 h-16 bg-orange-50 text-orange-500 rounded-full flex items-center justify-center mx-auto mb-6 text-2xl">
            <i class="fa-solid fa-unlock-keyhole"></i>
        </div>

        <h2 class="text-3xl font-light text-black mb-2">Quên <span class="font-bold">Mật Khẩu?</span></h2>
        <p class="text-xs text-zinc-400 mb-8 leading-relaxed">Đừng lo lắng! Nhập email của bạn dưới đây, chúng tôi sẽ gửi mã OTP để đặt lại mật khẩu.</p>

        @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            if (ViewBag.Error != null)
            {
                <div class="bg-red-50 text-red-500 p-3 rounded-xl text-[11px] font-bold mb-6 border border-red-100">
                    @ViewBag.Error
                </div>
            }

            <div class="space-y-6">
                <div class="relative group text-left">
                    <i class="fa-regular fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-zinc-300 group-focus-within:text-orange-500 transition-colors"></i>
                    <input type="email" name="Email" required placeholder="Nhập địa chỉ Email" class="w-full bg-zinc-50 border border-zinc-100 rounded-xl py-4 pl-12 pr-4 text-black text-sm font-medium focus:bg-white focus:border-orange-500 outline-none transition-all" />
                </div>

                <button type="submit" class="w-full bg-black hover:bg-orange-600 text-white py-4 rounded-full text-xs font-black uppercase tracking-widest transition-all">
                    Gửi mã xác nhận
                </button>
            </div>
        }

        <div class="mt-8">
            <a href="/Account/Login" class="text-zinc-400 hover:text-black text-[11px] font-bold uppercase tracking-widest transition-all">
                <i class="fa-solid fa-chevron-left mr-1"></i> Quay lại Đăng nhập
            </a>
        </div>
    </div>
</div>