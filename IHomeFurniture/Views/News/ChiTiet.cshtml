@model IHomeFurniture.Models.TINTUC
@{
    ViewBag.Title = Model.TieuDe;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="bg-zinc-50 py-12">
    <div class="max-w-4xl mx-auto px-6 bg-white p-10 md:p-16 rounded-3xl shadow-sm border border-zinc-100">

        @* Nút quay lại *@
        <a href="/" class="text-[10px] uppercase tracking-[0.2em] font-bold text-zinc-400 hover:text-orange-600 transition-colors mb-10 inline-flex items-center gap-2">
            <i class="fa-solid fa-arrow-left-long"></i> Trở về Trang chủ
        </a>

        @* Header Bài Viết *@
        <h1 class="text-3xl md:text-5xl font-black tracking-tighter text-zinc-900 mb-6 leading-tight">
            @Model.TieuDe
        </h1>

        <div class="flex items-center gap-6 text-[11px] text-zinc-500 uppercase tracking-widest mb-10 pb-10 border-b border-zinc-100 font-medium">
            <span><i class="fa-regular fa-calendar-days mr-2"></i> @(Model.NgayDang.HasValue ? Model.NgayDang.Value.ToString("dd/MM/yyyy") : "Đang cập nhật")</span>
            <span><i class="fa-regular fa-eye mr-2"></i> @Model.LuotXem Lượt xem</span>
            <span class="bg-orange-100 text-orange-600 px-3 py-1 rounded-full font-black">TIN TỨC NỘI THẤT</span>
        </div>

        @if (!string.IsNullOrEmpty(Model.AnhTin))
        {
            <div class="rounded-2xl overflow-hidden mb-12 shadow-lg">
                <img src="@Url.Content("~/Images/News/" + Model.AnhTin)"
                     onerror="this.src='https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&q=80'"
                     alt="@Model.TieuDe"
                     class="w-full h-auto object-cover max-h-[500px]" />
            </div>
        }

        @* Nội dung chi tiết - Dùng Html.Raw để nó dịch thẻ HTML của CKEditor *@
        <div class="prose prose-zinc prose-lg max-w-none text-zinc-600 leading-loose">
            @Html.Raw(Model.NoiDung)
        </div>

        @* Nút chia sẻ *@
        <div class="mt-16 pt-8 border-t border-zinc-100 flex items-center justify-between">
            <span class="text-sm font-bold text-zinc-900 uppercase tracking-widest">Chia sẻ bài viết</span>
            <div class="flex gap-4 text-xl text-zinc-400">
                <a href="#" class="hover:text-blue-600 transition-colors"><i class="fa-brands fa-facebook"></i></a>
                <a href="#" class="hover:text-sky-500 transition-colors"><i class="fa-brands fa-twitter"></i></a>
                <a href="#" class="hover:text-red-500 transition-colors"><i class="fa-brands fa-pinterest"></i></a>
            </div>
        </div>
    </div>
</div>