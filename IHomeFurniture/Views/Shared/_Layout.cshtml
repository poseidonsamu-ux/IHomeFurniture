<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - iHome</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>
<body class="bg-white text-gray-800">

    <nav class="flex justify-between items-center px-10 py-6 border-b border-gray-100 sticky top-0 bg-white z-50">
        <div class="text-2xl font-bold tracking-tighter text-black">
            <a href="@Url.Action("Index", "Home")">iHOME.</a>
        </div>

        <ul class="hidden lg:flex space-x-8 font-medium">
            <li><a href="@Url.Action("Index", "Home")" class="hover:text-gray-500 transition">Trang chủ</a></li>
            <li><a href="/Product" class="hover:text-gray-500 transition">Sản phẩm</a></li>
            <li><a href="#" class="hover:text-gray-500 transition">Bộ sưu tập</a></li>
            <li><a href="#" class="hover:text-gray-500 transition">Liên hệ</a></li>
        </ul>

        <form action="/Search" method="get" class="hidden md:flex items-center bg-gray-100 px-4 py-2 rounded-full w-64">
            <button type="submit"><i class="fa-solid fa-magnifying-glass text-gray-400 mr-2"></i></button>
            <input type="text" name="searchTerm" placeholder="Tìm kiếm..." class="bg-transparent border-none focus:outline-none text-sm w-full">
        </form>

        <div class="flex items-center space-x-6">
            @if (Session["TaiKhoan"] == null)
            {
                <a href="@Url.Action("Login", "Account")" class="flex items-center space-x-2 hover:text-gray-500 transition text-sm font-medium">
                    <i class="fa-regular fa-user text-lg"></i>
                    <span>Đăng nhập</span>
                </a>
            }
            else
            {
                <span class="text-sm font-medium">Chào, @Session["HoTen"]!</span>
                <a href="@Url.Action("Logout", "Account")" class="text-xs text-red-500">Thoát</a>
            }

            <a href="/Cart" class="flex items-center space-x-2 hover:text-gray-500 transition text-sm font-medium relative">
                <i class="fa-solid fa-cart-shopping text-lg"></i>
                <span>Giỏ hàng</span>
                <span class="absolute -top-2 -right-2 bg-black text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center">0</span>
            </a>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="bg-black text-white py-16 px-10">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 border-b border-gray-800 pb-12">
            <div class="col-span-1 md:col-span-1">
                <div class="text-2xl font-bold mb-6 text-white">iHOME.</div>
                <p class="text-gray-400">Kiến tạo không gian, dựng xây hạnh phúc.</p>
            </div>
            <div>
                <h5 class="font-bold mb-6">Hỗ trợ</h5>
                <ul class="text-gray-400 space-y-3">
                    <li><a href="#" class="hover:text-white transition">Giao hàng</a></li>
                    <li><a href="#" class="hover:text-white transition">Bảo hành</a></li>
                    <li><a href="#" class="hover:text-white transition">Đổi trả</a></li>
                </ul>
            </div>
            <div>
                <h5 class="font-bold mb-6">Công ty</h5>
                <ul class="text-gray-400 space-y-3">
                    <li><a href="#" class="hover:text-white transition">Giới thiệu</a></li>
                    <li><a href="#" class="hover:text-white transition">Showroom</a></li>
                    <li><a href="#" class="hover:text-white transition">Blog</a></li>
                </ul>
            </div>
            <div>
                <h5 class="font-bold mb-6">Đăng ký nhận tin</h5>
                <form action="/Newsletter/Subscribe" method="post" class="flex border-b border-gray-500 py-2">
                    <input type="email" name="email" placeholder="Email của bạn" class="bg-transparent border-none focus:outline-none w-full text-white">
                    <button type="submit" class="font-bold text-white">GỬI</button>
                </form>
            </div>
        </div>
        <div class="mt-10 text-gray-500 text-sm flex justify-between">
            <p>© 2026 iHome Interior. All rights reserved.</p>
            <div class="flex space-x-4">
                <a href="#" class="hover:text-white transition">FB</a>
                <a href="#" class="hover:text-white transition">IG</a>
                <a href="#" class="hover:text-white transition">YT</a>
            </div>
        </div>
    </footer>

    @RenderSection("scripts", required: false)
</body>
</html>