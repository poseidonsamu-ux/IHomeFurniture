@model IEnumerable<IHomeFurniture.Models.SANPHAM>
@{
    ViewBag.Title = "Trang chủ | iHOME Interior";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="relative h-[90vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 transition-transform duration-[2000ms] hover:scale-110">
        <img src="https://images.unsplash.com/photo-1618221195710-dd6b41faaea6" class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-black/30"></div>
    </div>
    <div class="relative text-center px-4">
        <p class="text-white text-sm uppercase tracking-[0.5em] mb-4 animate-fadeIn">Thiết kế bởi chuyên gia</p>
        <h1 class="text-6xl md:text-8xl font-thin text-white mb-8">Minimal <span class="font-bold">Living</span></h1>
        <a href="#featured" class="inline-block border border-white text-white px-10 py-4 hover:bg-white hover:text-black transition-all duration-500 uppercase text-xs tracking-widest">
            Khám phá ngay
        </a>
    </div>
</section>

<section class="py-24 px-6 max-w-[1600px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 ">
        <div class="md:col-span-6 relative group overflow-hidden rounded-sm">
            <img src="https://images.unsplash.com/photo-1583847268964-b28dc2f51ac9" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
            <div class="absolute inset-0 bg-black/10 group-hover:bg-black/40 transition-all"></div>
            <div class="absolute bottom-10 left-10 text-white">
                <h3 class="text-3xl font-bold mb-2">Bộ sưu tập <br>Phòng khách</h3>
                <a href="/Category/LivingRoom" class="text-sm underline underline-offset-8 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-4 group-hover:translate-y-0 inline-block">Xem ngay</a>
            </div>
        </div>

        <div class="md:col-span-6 grid grid-rows-2 gap-6">
            <div class="relative group overflow-hidden rounded-sm">
                <img src="https://images.unsplash.com/photo-1540518614846-7eded433c457" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
                <div class="absolute inset-0 bg-black/20 group-hover:bg-black/40 transition-all"></div>
                <div class="absolute bottom-6 left-6 text-white text-xl font-bold">Nội thất Phòng ngủ</div>
            </div>
            <div class="grid grid-cols-2 gap-6">
                <div class="relative group overflow-hidden rounded-sm">
                    <img src="https://images.unsplash.com/photo-1556911220-e15b29be8c8f" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
                    <div class="absolute inset-0 bg-black/20 group-hover:bg-black/40 transition-all"></div>
                    <p class="absolute inset-0 flex items-center justify-center text-white font-bold">Nhà bếp</p>
                </div>
                <div class="relative group overflow-hidden rounded-sm bg-zinc-100 flex flex-col items-center justify-center text-center p-4">
                    <h4 class="text-zinc-400 uppercase tracking-tighter text-xs mb-2">Xem thêm</h4>
                    <p class="font-bold text-zinc-800 uppercase">+15 Danh mục khác</p>
                    <a href="/Product" class="mt-4 w-10 h-10 border border-zinc-300 rounded-full flex items-center justify-center hover:bg-black hover:text-white transition-colors">→</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="featured" class="py-24 bg-white px-6">
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-4">
            <div class="max-w-md">
                <h2 class="text-4xl font-bold tracking-tighter mb-4 italic">Sản phẩm tiêu biểu</h2>
                <p class="text-zinc-500 text-sm">Những thiết kế được tuyển chọn kỹ lưỡng, mang phong cách tối giản nhưng không kém phần sang trọng.</p>
            </div>
            <div class="flex gap-4">
                <button class="px-6 py-2 border-b-2 border-black text-sm font-bold">Tất cả</button>
                <button class="px-6 py-2 text-zinc-400 text-sm hover:text-black transition-colors">Ghế</button>
                <button class="px-6 py-2 text-zinc-400 text-sm hover:text-black transition-colors">Bàn</button>
            </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-12">
            @if (Model != null && Model.Any())
            {
                foreach (var sp in Model)
                {
                    <div class="group">
                        <div class="relative overflow-hidden aspect-[4/5] bg-zinc-100 rounded-sm mb-4">
                            <img src="~/Images/@sp.AnhBia"
                                 onerror="this.src='https://images.unsplash.com/photo-1567538096630-e0c55bd6374c?auto=format&fit=crop&q=80'"
                                 class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">

                            <div class="absolute top-4 left-4 bg-black text-white text-[10px] px-2 py-1 uppercase tracking-widest">New</div>
                            <div class="absolute inset-x-0 bottom-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300 bg-gradient-to-t from-black/60 to-transparent">
                                <button class="w-full bg-white text-black py-3 text-xs font-bold hover:bg-black hover:text-white transition-colors flex items-center justify-center gap-2">
                                    <i class="fa-solid fa-cart-plus"></i> THÊM VÀO GIỎ
                                </button>
                            </div>
                        </div>
                        <div>
                            <a href="/Product/Details/@sp.MaSP" class="text-sm font-medium text-zinc-800 hover:underline decoration-zinc-300 underline-offset-4">@sp.TenSP</a>
                            <div class="flex items-center gap-3 mt-1">
                                <span class="text-sm font-bold text-black">@string.Format("{0:N0}đ", sp.GiaBan)</span>
                                @if (sp.GiaKhuyenMai > 0)
                                {
                                    <span class="text-[11px] text-zinc-400 line-through">@string.Format("{0:N0}đ", sp.GiaKhuyenMai)</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="mt-20 text-center">
            <a href="/Product" class="inline-block px-12 py-4 border border-zinc-200 text-zinc-800 text-xs font-bold tracking-[0.2em] hover:bg-black hover:text-white transition-all">
                XEM TẤT CẢ SẢN PHẨM
            </a>
        </div>
    </div>
</section>

<section class="py-24 bg-zinc-50 px-6">
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-4">
            <div class="max-w-md">
                <h2 class="text-4xl font-bold tracking-tighter mb-4 italic">Góc Cảm Hứng</h2>
                <p class="text-zinc-500 text-sm">Cập nhật những xu hướng thiết kế nội thất mới nhất và mẹo vặt trang trí không gian sống.</p>
            </div>
            <div>
                <a href="/News" class="text-xs font-bold uppercase tracking-[0.2em] underline underline-offset-4 hover:text-orange-600 transition-colors">Đọc tất cả bài viết</a>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            @{ var listTinTuc = ViewBag.TinTucMoi as IEnumerable<IHomeFurniture.Models.TINTUC>; }

            @if (listTinTuc != null && listTinTuc.Any())
            {
                foreach (var item in listTinTuc)
                {
                    <a href="/News/ChiTiet/@item.MaTin" class="block group cursor-pointer">
                        <div class="relative overflow-hidden aspect-[4/3] mb-6 rounded-sm">
                            <img src="~/Images/News/@item.AnhTin"
                                 onerror="this.src='https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&q=80'"
                                 class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                                 alt="@item.TieuDe">
                            <div class="absolute top-4 left-4 bg-white text-black text-[10px] px-3 py-1 uppercase tracking-widest font-bold">Blog</div>
                        </div>
                        <div class="flex items-center gap-4 text-[11px] text-zinc-400 uppercase tracking-widest mb-3">
                            <span><i class="fa-regular fa-calendar mr-1"></i> @(item.NgayDang.HasValue ? item.NgayDang.Value.ToString("dd/MM/yyyy") : "Mới nhất")</span>
                            <span><i class="fa-regular fa-eye mr-1"></i> @(item.LuotXem ?? 0) views</span>
                        </div>
                        <h3 class="text-xl font-bold mb-3 group-hover:text-orange-600 transition-colors">@item.TieuDe</h3>
                        <p class="text-zinc-500 text-sm line-clamp-2">@item.TomTat</p>
                    </a>
                }
            }
            else
            {
                <div class="col-span-3 text-center text-zinc-400 py-10">Đang cập nhật bài viết mới...</div>
            }
        </div>
    </div>
</section>

<section class="py-20">
    <div class="grid md:grid-cols-2 bg-zinc-900 text-white">
        <div class="p-16 flex flex-col justify-center">
            <h2 class="text-4xl font-light mb-6">Trải nghiệm <br><span class="font-bold italic text-zinc-400">Showroom thực tế</span></h2>
            <p class="text-zinc-400 mb-8 leading-relaxed font-light">Ghé thăm không gian trưng bày của chúng tôi tại TP. Hồ Chí Minh để trực tiếp cảm nhận chất liệu và sự tinh tế trong từng đường nét sản phẩm.</p>
            <div class="flex items-center gap-4">
                <i class="fa-solid fa-location-dot text-2xl text-zinc-500"></i>
                <span class="text-sm font-medium tracking-wide">123 Đường Decor, Quận 1, TP. HCM</span>
            </div>
        </div>
        <div class="h-[400px] md:h-auto overflow-hidden">
            <img src="https://images.unsplash.com/photo-1538688543444-5969567a57a6" class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-1000">
        </div>
    </div>
</section>